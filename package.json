{
  "name": "satisfactory",
  "version": "1.0.0",
  "private": true,
  "description": "Satisfactory Planner — game data, production calculator, factory and logistics tools.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22",
    "pnpm": "11.8.0"
  },
  "imports": {
    "#/*": "./src/*",
    "#convex/*": "./convex/*"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite dev --port 3000 --host",
    "dev:all": "pnpm exec convex dev --once && pnpm dev",
    "dev:watch": "concurrently -n convex,vite -c blue,green \"pnpm exec convex dev\" \"pnpm dev\"",
    "generate-routes": "tsr generate",
    "build": "vite build && node scripts/generate-sw.mjs",
    "build:development": "vite build --mode development && node scripts/generate-sw.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome check --write",
    "check": "biome check",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm run deploy:prod",
    "deploy:dev": "pnpm exec convex dev --once && pnpm run build:development && wrangler deploy --env dev",
    "deploy:prod": "pnpm exec convex deploy && pnpm run build && wrangler deploy",
    "generate-data": "node scripts/generate-data.ts",
    "vendor-nodes": "node scripts/vendor-resource-nodes.ts",
    "vendor-icons": "node scripts/vendor-icons.ts"
  },
  "dependencies": {
    "@appelent/auth": "^0.1.0",
    "@clerk/clerk-react": "^5.61.3",
    "@cloudflare/vite-plugin": "^1.43.0",
    "@convex-dev/react-query": "0.1.0",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.168.19",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "elkjs": "^0.11.1",
    "highs": "^1.14.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.167.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "workbox-build": "^7.4.1",
    "wrangler": "^4.107.0"
  }
}
